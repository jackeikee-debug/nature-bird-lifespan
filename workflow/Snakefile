rule audit_manuscript_claims:
    input:
        manuscript="docs/manuscript_draft_v1.md",
        waterfall="results/tables/phase3_evidence_waterfall_counts.tsv",
        impact="results/tables/phase3_gff_cds_plus_uniprot_sequence_rescue_model_impact.tsv",
        overlay="results/tables/phase3_gff_cds_plus_uniprot_combined_overlay_summary.tsv",
        bird_models="results/tables/phase3_gff_cds_plus_uniprot_sequence_rescued_bird_enriched_models.tsv",
        tree_summary="results/tables/gene_family_tree_validation_summary.tsv",
        trim_qc="results/tables/gene_family_trimmed_alignment_qc.tsv"
    output:
        table="results/tables/manuscript_claim_audit.tsv",
        report="results/reports/manuscript_claim_audit_report.md"
    shell:
        "python scripts/11_manuscript/audit_manuscript_claims.py --manuscript {input.manuscript} --table-output {output.table} --report {output.report}"
